{
  "name": "javascripto",
  "scopeName": "source.javascripto",
  "displayName": "JavaScripto",
  "aliases": ["jscripto"],
  "fileTypes": ["jscripto"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#support" },
    { "include": "#operators" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.javascripto",
          "match": "//.*$"
        },
        {
          "name": "comment.block.javascripto",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.javascripto",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.javascripto",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.javascripto",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.javascripto",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.javascripto",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.javascripto",
          "match": "\\b(se|senao|enquanto|para|retorne|quebre|continue|escolha|caso|padrao)\\b"
        },
        {
          "name": "storage.type.javascripto",
          "match": "\\b(deixe|fixe|funcao|classe)\\b"
        },
        {
          "name": "keyword.operator.new.javascripto",
          "match": "\\bnovo\\b"
        },
        {
          "name": "storage.type.constructor.javascripto",
          "match": "\\bconstrutor\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.javascripto",
          "match": "\\b(verdadeiro|falso)\\b"
        },
        {
          "name": "constant.language.null.javascripto",
          "match": "\\bnulo\\b"
        },
        {
          "name": "variable.language.this.javascripto",
          "match": "\\bisso\\b"
        }
      ]
    },
    "support": {
      "patterns": [
        {
          "name": "support.function.javascripto",
          "match": "\\bimprima\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.javascripto",
          "match": "===|!==|==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.javascripto",
          "match": "\\|\\||&&|!"
        },
        {
          "name": "keyword.operator.assignment.javascripto",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.javascripto",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.javascripto",
          "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)(?=\\s*\\()"
        },
        {
          "name": "variable.other.javascripto",
          "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.javascripto",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.parameters.javascripto",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.javascripto",
          "match": "[,;]"
        }
      ]
    }
  }
}
