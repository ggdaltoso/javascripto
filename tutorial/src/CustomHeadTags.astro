---
const siteUrl = 'https://javascripto.ggdaltoso.dev';
const description = 'Aprenda JavaScript escrevendo código em português. Tutorial interativo com transpilador em tempo real.';

// Derive the lesson-specific OG image from the current URL.
// e.g. /tutorial/1-fundamentos/1-primeiros-passos/1-ola-mundo → /og/1-fundamentos/1-primeiros-passos/1-ola-mundo.png
const lessonPath = Astro.url.pathname.replace(/^\/tutorial/, '');
const ogImage = lessonPath
  ? `${siteUrl}/og${lessonPath}.png`
  : `${siteUrl}/og.png`;
---
<slot name="title" />
<slot name="links" />
<slot name="meta" />
<script src="/coi-serviceworker.min.js" is:inline></script>

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="JavaScripto" />
<meta property="og:title" content="JavaScripto — Aprenda JavaScript em português" />
<meta property="og:description" content={description} />
<meta property="og:url" content={Astro.url.href} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="JavaScripto — Programe em português, pense em JavaScript" />
<meta property="og:locale" content="pt_BR" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="JavaScripto — Aprenda JavaScript em português" />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<style is:global>
  :root {
    --tk-scrollbar-track: transparent;
    --tk-scrollbar-thumb: #0000004d;
  }

  [data-theme="dark"] {
    --tk-scrollbar-thumb: #ffffff33;
  }

  /* Content pane (overrides .scrollbar-transparent from UnoCSS) */
  .scrollbar-transparent {
    scrollbar-width: thin;
    scrollbar-color: var(--tk-scrollbar-thumb) var(--tk-scrollbar-track);
  }

  .scrollbar-transparent::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  .scrollbar-transparent::-webkit-scrollbar-track {
    background: var(--tk-scrollbar-track);
  }

  .scrollbar-transparent::-webkit-scrollbar-thumb {
    background: var(--tk-scrollbar-thumb);
    border-radius: 3px;
  }

  /* CodeMirror editor */
  .cm-scroller {
    scrollbar-width: thin;
    scrollbar-color: var(--tk-scrollbar-thumb) var(--tk-scrollbar-track);
  }

  .cm-scroller::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  .cm-scroller::-webkit-scrollbar-track {
    background: var(--tk-scrollbar-track);
  }

  .cm-scroller::-webkit-scrollbar-thumb {
    background: var(--tk-scrollbar-thumb);
    border-radius: 3px;
  }

  /* xterm terminal */
  .xterm-viewport {
    scrollbar-width: thin;
    scrollbar-color: var(--tk-scrollbar-thumb) var(--tk-scrollbar-track);
  }

  .xterm-viewport::-webkit-scrollbar {
    width: 6px;
  }

  .xterm-viewport::-webkit-scrollbar-track {
    background: var(--tk-scrollbar-track);
  }

  .xterm-viewport::-webkit-scrollbar-thumb {
    background: var(--tk-scrollbar-thumb);
    border-radius: 3px;
  }

  /* Nav dropdown + file tree (overflow-auto/overflow-y-auto sem classe dedicada) */
  .nav-list-container,
  [class*="overflow-y-auto"],
  [class*="overflow-auto"] {
    scrollbar-width: thin;
    scrollbar-color: var(--tk-scrollbar-thumb) var(--tk-scrollbar-track);
  }

  [class*="overflow-y-auto"]::-webkit-scrollbar,
  [class*="overflow-auto"]::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  [class*="overflow-y-auto"]::-webkit-scrollbar-track,
  [class*="overflow-auto"]::-webkit-scrollbar-track {
    background: var(--tk-scrollbar-track);
  }

  [class*="overflow-y-auto"]::-webkit-scrollbar-thumb,
  [class*="overflow-auto"]::-webkit-scrollbar-thumb {
    background: var(--tk-scrollbar-thumb);
    border-radius: 3px;
  }
</style>
